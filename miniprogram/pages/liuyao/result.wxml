<!-- 六爻结果页面 -->
<view class="result-page" wx:if="{{ result }}">

  <!-- 卦象展示 -->
  <view class="hexagram-area">
    <text class="area-title">卦象</text>
    <hexagram-view
      primaryLines="{{ primary.lines }}"
      transformedLines="{{ transformed ? transformed.lines : null }}"
      changingLines="{{ result.changingLines }}"
      primaryName="{{ primary.name }}"
      transformedName="{{ transformed ? transformed.name : '' }}"
      lineRelations="{{ result.lineRelations }}"
      shiYao="{{ result.shiYao }}"
      yingYao="{{ result.yingYao }}"
    />
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="info-row">
      <text class="info-label">本卦</text>
      <text class="info-value">{{ primary.name }}</text>
      <text class="info-sub">({{ primary.palace }}宫·{{ primary.wuxing }})</text>
    </view>
    <view wx:if="{{ transformed }}" class="info-row">
      <text class="info-label">变卦</text>
      <text class="info-value">{{ transformed.name }}</text>
      <text class="info-sub">({{ transformed.palace }}宫·{{ transformed.wuxing }})</text>
    </view>
    <view wx:if="{{ result.changingLines.length > 0 }}" class="info-row">
      <text class="info-label">变爻</text>
      <text class="info-value">第 {{ result.changingLines[0] + 1 }}{{ result.changingLines.length > 1 ? '等' + result.changingLines.length + '爻' : '爻' }}</text>
    </view>
  </view>

  <!-- 解读摘要 -->
  <view class="card">
    <text class="card-title">📖 卦辞解读</text>
    <text class="card-text">{{ primary.judgement }}</text>
    <text wx:if="{{ transformed }}" class="card-text mt">{{ transformed.judgement }}</text>
  </view>

  <view class="card">
    <text class="card-title">💬 通俗解读</text>
    <text class="card-text">{{ result.interpretation.summary }}</text>
  </view>

  <view class="card">
    <text class="card-title">💡 建议</text>
    <text class="card-text advice">{{ result.interpretation.advice }}</text>
  </view>

  <view class="actions">
    <button class="dao-btn-primary" bindtap="onViewDetail">查看逐爻详解</button>
    <button class="dao-btn-outline" open-type="share">分享</button>
  </view>
</view>
