{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./miniprogram",
    "baseUrl": "./miniprogram",
    "paths": {
      "@services/*": ["services/*"],
      "@components/*": ["components/*"],
      "@data/*": ["data/*"],
      "@utils/*": ["utils/*"]
    },
    "typeRoots": ["./node_modules/miniprogram-api-typings"],
    "types": ["miniprogram-api-typings"]
  },
  "include": ["miniprogram/**/*.ts"],
  "exclude": ["node_modules", "cloud"]
}
