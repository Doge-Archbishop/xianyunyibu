<view class="result-page" wx:if="{{ result }}">
  <view class="page-title">八字排盘结果</view>

  <!-- 四柱表格 -->
  <view class="pillars-table">
    <view class="table-header">
      <text class="th">时柱</text><text class="th">日柱</text><text class="th">月柱</text><text class="th">年柱</text>
    </view>
    <view class="table-row gan-row">
      <text class="td">{{ result.pillars.hour.gan }}</text>
      <text class="td highlight">{{ result.pillars.day.gan }}</text>
      <text class="td">{{ result.pillars.month.gan }}</text>
      <text class="td">{{ result.pillars.year.gan }}</text>
    </view>
    <view class="table-row zhi-row">
      <text class="td">{{ result.pillars.hour.zhi }}</text>
      <text class="td highlight">{{ result.pillars.day.zhi }}</text>
      <text class="td">{{ result.pillars.month.zhi }}</text>
      <text class="td">{{ result.pillars.year.zhi }}</text>
    </view>
    <view class="table-row nayin-row">
      <text class="td sm">{{ result.nayin[3] }}</text>
      <text class="td sm">{{ result.nayin[2] }}</text>
      <text class="td sm">{{ result.nayin[1] }}</text>
      <text class="td sm">{{ result.nayin[0] }}</text>
    </view>
  </view>

  <!-- 日主 -->
  <view class="daymaster-card">
    <text class="dm-label">日主（你自己）</text>
    <text class="dm-value">{{ result.dayMaster }}（{{ result.dayMasterWuxing }}·{{ '' }}）</text>
  </view>

  <!-- 五行分布 -->
  <view class="card">
    <text class="card-title">🎨 五行分布</text>
    <view wx:for="{{ wuxingBars }}" wx:key="name" class="wuxing-bar">
      <text class="bar-label">{{ item.name }}</text>
      <view class="bar-track">
        <view class="bar-fill" style="width:{{ item.percent }}%; background:{{ item.color }}"></view>
      </view>
      <text class="bar-count">{{ item.count }}</text>
    </view>
  </view>

  <!-- 十神简表 -->
  <view class="card">
    <text class="card-title">🏷️ 十神（部分）</text>
    <view class="shishen-row">
      <text class="ss-item">年：{{ result.shiShen[0][0] }}</text>
      <text class="ss-item">月：{{ result.shiShen[1][0] }}</text>
      <text class="ss-item">日：日主</text>
      <text class="ss-item">时：{{ result.shiShen[3][0] }}</text>
    </view>
  </view>

  <!-- 大运 -->
  <view class="card" wx:if="{{ result.daYun.length > 0 }}">
    <text class="card-title">📅 大运</text>
    <view class="dayun-list">
      <view wx:for="{{ result.daYun }}" wx:key="startAge" wx:if="{{ index < 5 }}" class="dayun-item {{ item.isCurrent ? 'current' : '' }}">
        <text class="dy-age">{{ item.startAge }}岁</text>
        <text class="dy-ganzhi">{{ item.ganzhi.gan }}{{ item.ganzhi.zhi }}</text>
        <text wx:if="{{ item.isCurrent }}" class="dy-current">← 当前</text>
      </view>
    </view>
  </view>

  <button class="dao-btn-primary" bindtap="onViewAnalysis">查看详细分析</button>
</view>
